# Copy to scripts/testing.env.local for local overrides.
# Environment variables set when invoking scripts take precedence.

: "${MS1_API_BASE_URL:=}"
: "${MS4_API_BASE_URL:=}"

# Optional: set for live e2e smoke.
: "${SMOKE_CLASS_PASSWORD:=}"

# Optional smoke defaults.
: "${SMOKE_NICKNAME:=smokeuser}"
: "${SMOKE_CONTENT_TYPE:=image/png}"
: "${SMOKE_FILE_PATH:=img/ita-arch-diag1.png}"
: "${SMOKE_EXPECTED_FINAL_STATUS:=queued}"

export MS1_API_BASE_URL
export MS4_API_BASE_URL
export SMOKE_CLASS_PASSWORD
export SMOKE_NICKNAME
export SMOKE_CONTENT_TYPE
export SMOKE_FILE_PATH
export SMOKE_EXPECTED_FINAL_STATUS
