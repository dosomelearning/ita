# Ingress gateway mode:
# - mock (default): mock upload-init + mock upload transport.
# - ms1: call MS1 /v1/uploads/init and upload file to presigned S3 URL.
VITE_INGRESS_GATEWAY_MODE=mock

# Required when VITE_INGRESS_GATEWAY_MODE=ms1
VITE_MS1_API_BASE_URL=https://si01n8xiyc.execute-api.eu-central-1.amazonaws.com

# State gateway mode:
# - mock (default): fully mocked state progression.
# - ms4: poll MS4 status endpoint.
VITE_STATE_GATEWAY_MODE=ms4

# Required when VITE_STATE_GATEWAY_MODE=ms4
# Use your deployed MS4 API base URL (no trailing slash preferred).
VITE_MS4_API_BASE_URL=https://90zby48wa9.execute-api.eu-central-1.amazonaws.com
