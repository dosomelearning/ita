# State gateway mode:
# - mock (default): fully mocked state progression.
# - ms4: poll MS4 status endpoint.
VITE_STATE_GATEWAY_MODE=mock

# Required when VITE_STATE_GATEWAY_MODE=ms4
# Use your deployed MS4 API base URL (no trailing slash preferred).
VITE_MS4_API_BASE_URL=https://ita.dosomelearning.com
